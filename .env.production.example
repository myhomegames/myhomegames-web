# Production build (npm run build) — see also .env.production

# Local Node URL for /tunnel/* when the browser runs on the same machine as the server.
VITE_API_BASE=http://localhost:4000

# Remote browsers (GitHub Pages): bootstrap via Cloudflare Access + public tunnel URL.
VITE_CLOUDFLARE_TUNNEL_ENABLED=true
VITE_TUNNEL_MANAGER_URL=https://myhomegames-server.vige.it

# DO NOT use VITE_API_TOKEN in production - use Twitch OAuth instead

# Optional: GitHub repo for update notifications
#VITE_GITHUB_REPO=myhomegames/myhomegames-server
