# Git attributes for merge strategy
# Keep local .env version during merges (prevents overwriting production .env when merging from dev branch)
.env merge=ours

# Keep local .gitignore version during merges (prevents overwriting .gitignore when merging from main)
.gitignore merge=ours

# Keep public/ assets on main (PWA icons); SNAPSHOT ignores/untracks them
public/** merge=ours
