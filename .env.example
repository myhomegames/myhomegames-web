# Development configuration
# API_TOKEN for development authentication (development only)
# This is only used when Twitch OAuth is not configured
VITE_API_TOKEN=changeme

# Local Node URL (proxy target). With VITE_HTTPS_ENABLED=true, Vite forwards API paths here
# so the browser only uses https://localhost:5173 (no mixed content).
VITE_API_BASE=http://localhost:4000
#VITE_API_BASE=https://localhost:41440

# Production configuration notes:
# DO NOT use VITE_API_TOKEN in production - use Twitch OAuth instead
# For production, set VITE_API_BASE to your production API URL (e.g., https://api.yourdomain.com)
# The application will not start without VITE_API_BASE configured


# HTTPS Vite dev server (works with VITE_API_BASE=http://localhost:4000 via dev proxy)
VITE_HTTPS_ENABLED=true
#VITE_HTTPS_ENABLED=false

# Optional: GitHub repo "owner/repo" for update notifications
# When set, the app checks GitHub releases and shows a yellow notification icon when a newer version is available
#VITE_GITHUB_REPO=owner/repo
