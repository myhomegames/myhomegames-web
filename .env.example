# Development configuration
# Optional dev token for /auth/me (development only)
VITE_API_TOKEN=changeme

# Local Node URL for /tunnel/* control endpoints (connect, status, logout).
# App API calls use the public tunnel URL (same as production) once cloudflared is connected.
VITE_API_BASE=http://localhost:4000

# Production configuration notes:
# DO NOT use VITE_API_TOKEN in production
# The application will not start without VITE_API_BASE configured

# HTTPS for Vite dev/preview server (SPA on https://localhost:5173/app/ → API on tunnel subdomain)
VITE_HTTPS_ENABLED=true
#VITE_HTTPS_ENABLED=false

# Optional: tunnel manager base URL (default https://myhomegames-server.vige.it)
#VITE_TUNNEL_MANAGER_URL=https://myhomegames-server.vige.it

# Set in .env.production for GitHub Pages / remote browsers (Cloudflare Tunnel bootstrap).
#VITE_CLOUDFLARE_TUNNEL_ENABLED=true

# Optional: GitHub repo "owner/repo" for update notifications
#VITE_GITHUB_REPO=owner/repo

# Optional: GitHub repo for official skin release checks (default: myhomegames/myhomegames-skins)
#VITE_SKINS_GITHUB_REPO=myhomegames/myhomegames-skins
